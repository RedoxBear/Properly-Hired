# Frontend Configuration
# Copy this file to .env and fill in your actual values
# Note: Vite requires VITE_ prefix for environment variables

# Backend API URL
VITE_API_URL=http://localhost:3000

# Base44 API Configuration
VITE_BASE44_API_KEY=your_base44_api_key_here
VITE_BASE44_APP_ID=your_base44_app_id_here

# AI Service Configuration
# Set to 'true' to use backend AI endpoints (Kyle & Simon agents)
# Set to 'false' to use Base44's InvokeLLM (default)
VITE_USE_BACKEND_AI=false

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
