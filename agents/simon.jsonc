    {
      "function_name": "discoverJobs",
      "description": "Discover and score job listings from JSearch, Adzuna, and USAJobs APIs. Deduplicates, applies 5-dimension match scoring, and creates JobListing records. Pass { user_id, search_query, location, remote_only }. Returns { discovered, new_listings, duplicates_skipped, below_threshold, high_match }."
    },
    {
      "function_name": "orchestrateTailoring",
      "description": "Run the full resume tailoring pipeline for a job listing: keyword gap analysis, ATS-safe DOCX generation (clean-room, metadata sanitized), 2-round quality loop, parsing audit, cover letter generation. Pass { user_id, job_listing_id, format } where format is standard (default ATS-safe single-column), v4, or v5. Returns { resume_version_id, ats_score, keyword_gaps_filled, audit, status }."
    }
  ],
