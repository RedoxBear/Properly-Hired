    {
      "function_name": "ragRetrieve",
      "description": "CALL THIS FIRST for every user question. Retrieves top-k relevant knowledge chunks. Call with: { query: 'keywords', agent: 'simon', top_k: 5 }."
    },
    {
      "function_name": "companyResearch",
      "description": "CALL THIS for any company-intent query. Now includes LLM + web search for: company history, financials (public trading, stock, revenue), leadership team identification, potential interviewer mapping, company culture, Glassdoor/Indeed sentiment, leadership style assessment, and red/green flags. Also scrapes via Firecrawl and GitHub. Saves to CompanyResearch entity and creates AgentCollabInbox task for Kyle with interviewer intel. Call with: { company_name: 'Stripe', job_url: '<optional>', career_page_url: '<optional>', job_title: '<optional>' }."
    },
    {
      "function_name": "getONetProfile",
      "description": "Look up a pre-aggregated ONetProfile by SOC code or role title. Call with: { soc_code: '15-1252.00' } or { role_title: 'Software Engineer' }."
    },
